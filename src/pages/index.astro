<script is:inline>
  const cases = {
    MiniEvents: {
      tag: 'Live Events · Engagement · Retention · Comeback',
      title: 'Live Event Template Sets',
      images: ['/MMMiniEvents_1.png', '/MMMiniEvents_2.png','/MMMiniEvents_3.png','/MMMiniEvents_4.png'],
      role: 'Senior Game Designer',
      description: 'Set of 4 unique milestone progression recurring mini-events to drive retention, engagement and catch-up mechanics during longer main events. <br> I created the initial concept for the mini-events templates based on product needs; created designer wireframes using Figma wireframing design systems set in place by the UX team. <br> After getting all the approvals, I worked with QV to create adequate TFCs requirements for the features; and shepherded the mini-events through to the live team handover. ',
      tools: ['Figma', 'Perforce', 'XML', 'Visual Scripting', 'Jaas', 'Atlassian Suite']
    },
    SocialFeatures: {
      tag: 'Competitive · Co-op · Social',
      title: 'Social Utility Features',
      images: ['/MM_LeagueRequests.png', '/MM_LeagueTrades.png','/MM_LeagueContribution.png'],
      role: 'Senior Game Designer',
      description: 'Social Utility features to enhance player interaction and community building. <br> I was responsible for the design and implementation of 3 social utility features: <em>League Bank, League Trades and League Contribution</em>. <br>I worked closely with the product manager to identify the needs and goals for the features, and then created detailed design documents and wireframes using Figma. I collaborated with the engineering team to ensure the features were implemented according to design specifications.',
      tools: ['Figma', 'Perforce', 'XML', 'Visual Scripting', 'Jaas', 'Atlassian Suite']
    },
    UtilityFeatures: {
      tag: 'QOL · Albums · Management · Trade Look-up',
      title: 'Utility Features',
      images: ['/MMAlbums_feature.png', '/MMAlbums_feature2.png','/MMTradeLookUp.png','/MMTradeLookUp_1.png'],
      role: 'Senior Game Designer',
      description: 'Utility, quality of life features to improve player interaction with the game systems. <br><em>Albums</em> is a feature that allows players to view and manage their collection of players and items in a more organized way.<br><em>Trade Look-up</em> is a feature that allows players to quickly look if the cards they obtained in cardpacks can be used in any game valuable trade straight from the pack opening screen. <br> I was responsible for the design and implementation of these features, working closely with the product manager and engineering team to ensure they were implemented according to design specifications.',
      tools: ['Figma', 'Perforce', 'XML', 'Visual Scripting', 'Jaas', 'Atlassian Suite']
    },
  };

 function openCase(id) {
    const c = cases[id];
    const gallery = document.getElementById('overlay-gallery');
    Array.from(gallery.querySelectorAll('img')).forEach(i => i.remove());
    c.images.forEach((src, i) => {
      const img = document.createElement('img');
      img.src = src;
      img.className = 'overlay-img' + (i === 0 ? ' active' : '');
      img.alt = 'Screenshot ' + (i + 1);
      gallery.insertBefore(img, gallery.querySelector('.gallery-controls'));
    });
    document.getElementById('overlay-counter').textContent = '1 / ' + c.images.length;
    document.getElementById('overlay-content').innerHTML = `
      <p class="overlay-tag">${c.tag}</p>
      <h2 class="overlay-title">${c.title}</h2>
      <div class="overlay-field"><p class="overlay-field-label">My role</p><p class="overlay-field-value">${c.role}</p></div>
      <div class="overlay-field"><p class="overlay-field-label">Overview</p><p class="overlay-field-value">${c.description}</p></div>
      <div class="overlay-field">
  		<p class="overlay-field-label">Tools</p>
  		<div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem;">
    		${c.tools.map(t => `<span class="skill-tag">${t}</span>`).join('')}
  		</div>
</div>
    `;
    document.getElementById('overlay').classList.add('active');
	document.body.style.overflow = 'hidden';
  }

function cycleOverlay(direction) {
  const gallery = document.getElementById('overlay-gallery');
  const imgs = gallery.querySelectorAll('.overlay-img');
  const counter = document.getElementById('overlay-counter');
  let current = [...imgs].findIndex(img => img.classList.contains('active'));
  imgs[current].classList.remove('active');
  current = (current + direction + imgs.length) % imgs.length;
  imgs[current].classList.add('active');
  counter.textContent = (current + 1) + ' / ' + imgs.length;
}

  function closeOverlay(e) {
  if (e.target === document.getElementById('overlay')) {
    document.getElementById('overlay').classList.remove('active');
    document.body.style.overflow = '';
  }
}

</script>

</body>
</html>