<body>
  <style is:global>
  :root {
  --bg-primary: #0e0d0c;
  --border-subtle: #1e2420;
  --border-mid: #1e2e20;
  --text-primary: #d8e8d8;
  --text-secondary: #4a6b50;
  --text-muted: #3a5a40;
  --accent-gold: #c8a84a;
  --accent-gold-hover: #d4b855;
  --accent-sage: #7aab82;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'DM Sans', sans-serif; background: var(--bg-primary); color: var(--text-secondary); }
nav { display: flex; justify-content: space-between; align-items: center; padding: 2rem 3rem; border-bottom: 0.5px solid var(--border-subtle); position: sticky; top: 0; z-index: 100; background: var(--bg-primary); }
.nav-logo { font-family: 'Cormorant Garamond', serif; font-size: 22px; color: var(--text-primary); letter-spacing: 0.04em; }
.nav-links { display: flex; gap: 2.5rem; }
.nav-links a { font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-sage); text-decoration: none; }
.nav-links a:hover { color: var(--text-secondary); }
.hero-title { font-family: 'Cormorant Garamond', serif; font-size: 72px; font-weight: 400; line-height: 1.0; color: var(--text-primary); }
.hero-title em { font-style: normal; color: var(--text-primary); }
.hero-sub { font-size: 18px; font-weight: 300; color: var(--text-sage); line-height: 1.7; max-width: 360px; margin-top: 1.5rem; }
.cta-row { display: flex; gap: 1rem; margin-top: 2.5rem; }
.btn-primary { background: var(--accent-gold); color: var(--bg-primary); font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.75rem 1.75rem; border: none; cursor: pointer; font-family: 'DM Sans', sans-serif; font-weight: 500; text-decoration: none; }
.btn-primary:hover { background: var(--accent-gold-hover); }
.btn-ghost { background: transparent; color: var(--text-sage); font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.75rem 1.75rem; border: 0.5px solid var(--border-mid); cursor: pointer; font-family: 'DM Sans', sans-serif; text-decoration: none; }
.btn-ghost:hover { border-color: var(--text-sage); color: var(--text-secondary); }
.section { padding: 4rem 3rem; border-bottom: 0.5px solid var(--border-subtle); }
.section-label { font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-sage); margin-bottom: 2.5rem; }
.work-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--border-subtle); }
.work-card { background: var(--bg-primary); padding: 2rem; }
.work-tag { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-sage); margin-bottom: 1rem; }
.work-title { font-family: 'Cormorant Garamond', serif; font-size: 28px; color: var(--text-primary); line-height: 1.2; margin-bottom: 0.5rem; }
.work-desc { font-size: 13px; color: var(--text-muted); line-height: 1.6; }
.about-grid { display: grid; grid-template-columns: 2fr 3fr; gap: 4rem; }
.about-role { font-family: 'Cormorant Garamond', serif; font-size: 36px; color: var(--text-primary); line-height: 1.2; margin-bottom: 1.5rem; }
.about-role em { font-style: italic; color: var(--accent-gold); }
.about-body { font-size: 14px; color: var(--text-sage); line-height: 1.8; }
.about-body p { margin-bottom: 1rem; }
.skills-list { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 2rem; }
.skill-tag { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); border: 0.5px solid var(--border-subtle); padding: 0.4rem 0.75rem; }
.contact-row { display: flex; align-items: center; justify-content: space-between; }
.contact-headline { font-family: 'Cormorant Garamond', serif; font-size: 52px; color: var(--text-primary); line-height: 1.1; }
.contact-headline em { font-style: italic; color: var(--accent-gold); }
.contact-btns { display: flex; flex-direction: column; gap: 1rem; align-items: flex-end; }
.footer { padding: 2rem 3rem; display: flex; justify-content: space-between; align-items: center; }
.footer-text { font-size: 12px; color: var(--border-mid); }
.footer-links { display: flex; gap: 2rem; }
.footer-links a { font-size: 12px; color: var(--text-muted); text-decoration: none; }
.footer-links a:hover { color: var(--accent-gold); }
.card-gallery { position: relative; width: 80%; max-width: 700px; aspect-ratio: 16/9; margin-bottom: 1.5rem; background: var(--bg-primary); overflow: hidden; }
.gallery-img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: contain; opacity: 0; transition: opacity 0.3s; }
.gallery-img.active { opacity: 1; }
.gallery-controls { position: absolute; bottom: 0.75rem; right: 0.75rem; display: flex; align-items: center; gap: 0.5rem; }
.gallery-btn { background: var(--bg-primary); color: var(--text-sage); border: 0.5px solid var(--border-subtle); font-size: 12px; padding: 0.25rem 0.6rem; cursor: pointer; font-family: 'DM Sans', sans-serif; }
.gallery-btn:hover { color: var(--text-primary); }
.gallery-counter { font-size: 10px; color: var(--text-sage); letter-spacing: 0.08em; border: 0.5px solid var(--border-subtle); background: var(--bg-primary); padding: 0.2rem 0.5rem; }
.overlay { display: none; position: fixed; inset: 0; background: rgba(14, 13, 12, 0.85); z-index: 200; align-items: center; justify-content: center; padding: 2rem; }
.overlay.active { display: flex; }
.overlay-inner { background: var(--bg-primary); border: 0.5px solid var(--border-subtle); width: 100%; max-width: 900px; max-height: 90vh; overflow-y: auto; display: flex; flex-direction: column; position: relative; }
.overlay-content { padding: 2.5rem 2.5rem 0 2.5rem; }
.overlay-gallery { width: 100%; aspect-ratio: 16/9; background: var(--bg-primary); position: relative; overflow: hidden; margin-top: 2rem; margin-bottom: 2rem;}
.overlay-gallery .overlay-img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: contain; opacity: 0; transition: opacity 0.3s; pointer-events: none; }
.overlay-gallery .overlay-img.active { opacity: 1; }
.overlay-img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: contain; opacity: 0; transition: opacity 0.3s; pointer-events: none; }
.overlay-img.active { opacity: 1; pointer-events: auto; }
.overlay-close { position: absolute; top: 1rem; right: 1rem; background: none; border: none; color: var(--text-sage); font-size: 20px; cursor: pointer; z-index: 201; }
.overlay-close:hover { color: var(--text-primary); }
.overlay-tag { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-sage); margin-bottom: 0.75rem; }
.overlay-title { font-family: 'Cormorant Garamond', serif; font-size: 32px; color: var(--text-primary); line-height: 1.2; margin-bottom: 1.5rem; }
.overlay-field { margin-bottom: 1.5rem; }
.overlay-field-label { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-sage); margin-bottom: 0.4rem; }
.overlay-field-value { font-size: 15px; color: var(--text-muted); line-height: 1.7; }
.btn-case { display: inline-block; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-sage); border: 0.5px solid var(--border-mid); padding: 0.4rem 0.9rem; cursor: pointer; background: none; font-family: 'DM Sans', sans-serif; margin-top: 1rem; }
.btn-case:hover { color: var(--accent-gold); border-color: var(--accent-gold); }

@media (max-width: 768px) {
  nav { padding: 1.25rem 1.5rem; }
  .nav-links { gap: 1.25rem; }
  .nav-links a { font-size: 10px; }

  section[style*="grid-template-columns: 1fr auto 1fr"] > div:first-child { 
    grid-template-columns: 1fr !important; 
  }
  
  .work-grid { grid-template-columns: 1fr; }
  .about-grid { grid-template-columns: 1fr; gap: 2rem; }
  
  .hero-title { font-size: 48px; }
  .contact-headline { font-size: 36px; }
  
  .overlay { padding: 0; align-items: flex-end; }
  .overlay-inner { max-height: 92vh; border-radius: 0; border-left: none; border-right: none; border-bottom: none; }
  .overlay-gallery { aspect-ratio: 16/9; min-height: 250px; }

  .hero-grid { grid-template-columns: 1fr !important; }
  .hero-grid > div[style*="width: 0.5px"] { display: none; }

  .section { padding: 2.5rem 1.5rem; }
  footer { padding: 1.5rem; }
}
